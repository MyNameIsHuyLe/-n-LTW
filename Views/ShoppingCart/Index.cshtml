@model website_ban_hang.Models.ShoppingCart

@{
    ViewData["Title"] = "Giỏ Hàng Của Bạn";
}

<h2 class="mb-4">
    <i class="bi bi-cart-fill"></i>
    Giỏ Hàng Của Bạn
</h2>

@if (Model != null && Model.Items != null && Model.Items.Any())
{
    <div class="table-responsive shadow-sm rounded bg-white">
        <table class="table table-hover align-middle mb-0">

            ```
            <thead class="table-dark">
                <tr>
                    <th class="py-3">Sản phẩm</th>
                    <th class="py-3">Số lượng</th>
                    <th class="py-3">Đơn giá</th>
                    <th class="py-3">Thành tiền</th>
                    <th class="py-3 text-center">Thao tác</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>

                        <td>@item.Quantity</td>

                        <td>
                            @item.Price.ToString("#,##0") VNĐ
                        </td>

                        <td>
                            @((item.Price * item.Quantity).ToString("#,##0")) VNĐ
                        </td>

                        <td class="text-center">
                            <a asp-controller="ShoppingCart"
                               asp-action="RemoveFromCart"
                               asp-route-productId="@item.ProductId"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Bạn có chắc muốn xóa sản phẩm này?')">

                                <i class="bi bi-trash"></i>
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>

        </table>
    </div>

    <div class="row mt-4 align-items-center">

        <div class="col-md-6 mb-3 mb-md-0">

            <a asp-controller="Home"
               asp-action="Index"
               class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left"></i>
                Tiếp tục mua sắm
            </a>

        </div>

        <div class="col-md-6 text-md-end">

            <h4 class="mb-3">
                Tổng tiền:

                <span class="text-danger fw-bold">
                    @Model.Items.Sum(i => i.Price * i.Quantity).ToString("#,##0") VNĐ
                </span>
            </h4>

            <a asp-controller="ShoppingCart"
               asp-action="Checkout"
               class="btn btn-success btn-lg px-4 shadow-sm">

                <i class="bi bi-credit-card-2-front"></i>
                Thanh toán
            </a>

        </div>

    </div>

}
else
{

    <div class="text-center py-5 shadow-sm bg-white rounded">

        ```
        <i class="bi bi-cart-x text-muted"
           style="font-size:4rem;"></i>

        <h4 class="mt-3 text-secondary">
            Giỏ hàng của bạn đang trống!
        </h4>

        <p class="text-muted">
            Hãy chọn sản phẩm trước khi thanh toán.
        </p>

        <a asp-controller="Home"
           asp-action="Index"
           class="btn btn-primary">

            <i class="bi bi-house-door"></i>
            Tiếp tục mua sắm
        </a>

    </div>


}
