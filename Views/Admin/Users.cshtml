@model IEnumerable<website_ban_hang.Models.Customer>

<h2>Quản lý tài khoản</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>SĐT</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th width="250">Thao tác</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>@user.Role</td>

                <td>
                    @if (user.IsActive)
                    {
                        <span class="badge bg-success">
                            Hoạt động
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-danger">
                            Đã khóa
                        </span>
                    }
                </td>

                <td>

                    <a asp-action="ChangeRole"
                       asp-route-id="@user.Id"
                       class="btn btn-warning btn-sm">
                        Đổi quyền
                    </a>

                    @if (user.IsActive)
                    {
                        <a asp-action="ToggleUserStatus"
                           asp-route-id="@user.Id"
                           class="btn btn-danger btn-sm">
                            Khóa
                        </a>
                    }
                    else
                    {
                        <a asp-action="ToggleUserStatus"
                           asp-route-id="@user.Id"
                           class="btn btn-success btn-sm">
                            Mở khóa
                        </a>
                    }

                </td>
            </tr>
        }
    </tbody>
</table>